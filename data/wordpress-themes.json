[
  {
    "id": "astra",
    "name": "Astra",
    "category": "wordpress-theme",
    "tags": ["多功能", "快速", "蓝紫", "现代"],
    "style": "品牌色以蓝紫渐变为核心视觉标识，搭配金黄色强调色。作为以速度和灵活性著称的多功能主题，配色方案强调可定制性，提供9个全局颜色槽位和3套可切换调色板。",
    "colors": {
      "primary": "#0170B9",
      "secondary": "#492CDD",
      "accent": "#FFC300",
      "background": "#F2F5F7",
      "surface": "#FFFFFF",
      "text": "#3A3A3A",
      "textSecondary": "#757575",
      "border": "#E5E5E5"
    },
    "darkMode": {
      "background": "#0C073B",
      "surface": "#1A1550",
      "text": "#F2F5F7"
    },
    "cssVariables": ":root {\n  --color-primary: #0170B9;\n  --color-secondary: #492CDD;\n  --color-accent: #FFC300;\n  --color-background: #F2F5F7;\n  --color-surface: #FFFFFF;\n  --color-text: #3A3A3A;\n  --color-text-secondary: #757575;\n  --color-border: #E5E5E5;\n}",
    "tailwindConfig": "colors: {\n  primary: '#0170B9',\n  secondary: '#492CDD',\n  accent: '#FFC300',\n}"
  },
